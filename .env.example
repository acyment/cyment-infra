# Caddy Admin Credentials
PB_ADMIN_EMAIL=alan@cyment.com
PB_ADMIN_PASSWORD=dtsuX6V5oF8d5bj

# GitHub Personal Access Token for cloning private repos
# Generate at: https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=ghp_your_token_here

# Botini Database Credentials
BOTINI_DB_PASSWORD=your_secure_password_here

# Botini JWT Secret (generate with: openssl rand -base64 32)
BOTINI_JWT_SECRET=your_jwt_secret_here

# Google OAuth (optional - for Google Drive integration)
BOTINI_GOOGLE_CLIENT_ID=
BOTINI_GOOGLE_DRIVE_API_KEY=

# BackIn15 Web Build Arguments
BACKIN15_VITE_APTABASE_APP_KEY=
BACKIN15_VITE_SENTRY_DSN=
BACKIN15_VITE_APP_VERSION=1.0.0
BACKIN15_VITE_APP_IS_RELEASED=true
BACKIN15_VITE_IOS_APP_STORE_URL=
BACKIN15_VITE_ANDROID_PLAY_STORE_URL=
BACKIN15_VITE_QR_CODE_URL=
BACKIN15_VITE_IOS_BUNDLE_ID=com.cyment.backin15
BACKIN15_VITE_ANDROID_PACKAGE_NAME=com.cyment.backin15

# BackIn15 App IDs (from Firebase Console)
BACKIN15_IOS_TEAM_ID=
BACKIN15_IOS_APP_ID=
BACKIN15_ANDROID_APP_ID=

# XCSteward website (xcsteward.com) — Docker build args (all optional).
# Changing any of these requires a rebuild (docker compose up -d --build).
XCSTEWARD_SITE_URL=https://xcsteward.com
# Analytics — pick one provider; leave blank for none (cookieless only).
XCSTEWARD_ANALYTICS_PROVIDER=
XCSTEWARD_PLAUSIBLE_DOMAIN=
XCSTEWARD_UMAMI_WEBSITE_ID=
XCSTEWARD_UMAMI_SRC=
XCSTEWARD_CLOUDFLARE_ANALYTICS_TOKEN=
# Google Search Console verification (URL-prefix meta-tag method).
XCSTEWARD_GOOGLE_SITE_VERIFICATION=
