# Caddy Admin Credentials
PB_ADMIN_EMAIL=admin@cyment.com
PB_ADMIN_PASSWORD=your-secure-password-here

# GitHub Personal Access Token for cloning private repos
# Generate at: https://github.com/settings/personal-access-tokens/new
# 1. Click "Generate new token" (fine-grained)
# 2. Name: "Cyment Infra VPS"
# 3. Expiration: 90 days
# 4. Select repositories: backin15, botini.club
# 5. Permissions: Contents (Read-only)
# 6. Copy the token (starts with ghp_)
# 7. Paste it below
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# BackIn15 Web Build Arguments
# These are used during the Docker build process for the web app

# Aptabase analytics key (optional)
BACKIN15_VITE_APTABASE_APP_KEY=

# Sentry error tracking DSN (optional)
BACKIN15_VITE_SENTRY_DSN=

# App version for the web build
BACKIN15_VITE_APP_VERSION=1.0.0

# Whether the app is released (affects display)
BACKIN15_VITE_APP_IS_RELEASED=true

# App Store URLs (optional)
BACKIN15_VITE_IOS_APP_STORE_URL=
BACKIN15_VITE_ANDROID_PLAY_STORE_URL=

# QR Code URL for app download (optional)
BACKIN15_VITE_QR_CODE_URL=

# Bundle identifiers
BACKIN15_VITE_IOS_BUNDLE_ID=com.cyment.backin15
BACKIN15_VITE_ANDROID_PACKAGE_NAME=com.cyment.backin15
